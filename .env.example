# Google API Key
GOOGLE_API_KEY=
GOOGLE_API_VERSION_OVERRIDE=v1
# Bluesky Credentials
BLUESKY_USERNAME=
BLUESKY_PASSWORD=

LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT="bluesky-agent-debug"

# Optional: LLM Model (default is gemini-1.5-pro)
# LLM_MODEL=gemini-pro

# Optional: Temperature for LLM responses (0-1, default is 0.7)
# LLM_TEMPERATURE=0.7

# Optional: Number of posts to fetch (default is 20)
POST_LIMIT=100
