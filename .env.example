# Google API Key
GOOGLE_API_KEY=
GOOGLE_API_VERSION_OVERRIDE=v1
# Bluesky Credentials
BLUESKY_USERNAME=
BLUESKY_PASSWORD=

LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT="bluesky-agent-debug"

# Optional: LLM Model (default is gemini-1.5-pro)
# LLM_MODEL=gemini-pro

# Optional: Temperature for LLM responses (0-1, default is 0.7)
# LLM_TEMPERATURE=0.7

# Optional: Number of posts to fetch (default is 20)
POST_LIMIT=100

# Optional: Send summary email using Gmail OAuth
GMAIL_OAUTH_ENABLED=false
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_OAUTH_FLOW=local
SUMMARY_EMAIL_TO=

# Optional: Send audio summary to Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Text-to-speech voice (default: en-US-AriaNeural)
# See: https://github.com/rany2/edge-tts for available voices
EDGE_TTS_VOICE=en-US-AriaNeural
